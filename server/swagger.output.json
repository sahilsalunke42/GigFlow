{
  "openapi": "3.0.3",
  "info": {
    "title": "Smart Leads Dashboard API",
    "description": "API documentation for the Smart Leads Dashboard assignment.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://gigflow-pysn.onrender.com",
      "description": "Production"
    },
    {
      "url": "http://localhost:3000",
      "description": "Local development"
    }
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "description": "",
        "responses": {
          "201": {
            "description": "User registered successfully"
          },
          "400": {
            "description": "Validation error"
          }
        },
        "summary": "User Registration",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  },
                  "role": {
                    "type": "string",
                    "enum": [
                      "admin",
                      "sales"
                    ]
                  }
                },
                "required": [
                  "name",
                  "email",
                  "password"
                ]
              },
              "example": {
                "name": "Jane Doe",
                "email": "jane@example.com",
                "password": "secret123",
                "role": "sales"
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "description": "",
        "responses": {
          "200": {
            "description": "JWT token and user details"
          },
          "400": {
            "description": "Invalid email or password"
          }
        },
        "summary": "User Login",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                },
                "required": [
                  "email",
                  "password"
                ]
              },
              "example": {
                "email": "jane@example.com",
                "password": "secret123"
              }
            }
          }
        }
      }
    },
    "/api/auth/refresh": {
      "post": {
        "description": "",
        "responses": {
          "default": {
            "description": ""
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/leads": {
      "post": {
        "description": "",
        "responses": {
          "201": {
            "description": "Lead created successfully"
          },
          "400": {
            "description": "Validation error"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Create Lead",
        "tags": [
          "Leads"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "phone": {
                    "type": "string"
                  },
                  "company": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "new",
                      "contacted",
                      "qualified",
                      "lost"
                    ]
                  },
                  "source": {
                    "type": "string",
                    "enum": [
                      "website",
                      "instagram",
                      "referral"
                    ]
                  },
                  "notes": {
                    "type": "string"
                  },
                  "value": {
                    "type": "number"
                  },
                  "assignedTo": {
                    "type": "string"
                  }
                },
                "required": [
                  "name",
                  "email"
                ]
              },
              "example": {
                "name": "Acme Lead",
                "email": "lead@acme.com",
                "status": "new",
                "source": "website"
              }
            }
          }
        }
      },
      "get": {
        "description": "",
        "responses": {
          "default": {
            "description": ""
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "View Leads List",
        "tags": [
          "Leads"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by Status"
          },
          {
            "name": "source",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by Source"
          },
          {
            "name": "sortBy",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sortOrder",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "latest",
                "oldest"
              ]
            },
            "description": "Sort by Latest or Oldest"
          }
        ]
      }
    },
    "/api/leads/export": {
      "get": {
        "description": "",
        "responses": {
          "200": {
            "description": "CSV file download"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "CSV Export Functionality",
        "tags": [
          "Leads"
        ]
      }
    },
    "/api/leads/{id}": {
      "get": {
        "description": "",
        "responses": {
          "200": {
            "description": "Lead details"
          },
          "404": {
            "description": "Lead not found"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "View Single Lead Details",
        "tags": [
          "Leads"
        ]
      },
      "put": {
        "description": "",
        "responses": {
          "200": {
            "description": "Lead updated successfully"
          },
          "404": {
            "description": "Lead not found"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Update Lead",
        "tags": [
          "Leads"
        ]
      },
      "delete": {
        "description": "",
        "responses": {
          "200": {
            "description": "Lead deleted successfully"
          },
          "404": {
            "description": "Lead not found"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Delete Lead",
        "tags": [
          "Leads"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}